<div class="container">
  <h4>Add passages to your memory list</h4>
  <hr/>
  <div class="row">
    <div class="col-md-6 form-inline">
      <input 
        name="bibleBook" 
        (focus)="$event.target.select()" 
        type="text" 
        placeholder="Enter a book of the Bible" 
        ngxTypeahead 
        [value]="bibleBook" 
        [ngbTypeahead]="search" 
        (selectItem)="handleBibleBookSelected($event)">
      &nbsp;Transl: &nbsp;
      <input 
        (focus)="$event.target.select()" 
        [ngbTypeahead]="searchTranslations" 
        [value]="translation" 
        (selectItem)="changeTranslation($event)" 
        size="2" 
        width="2" 
        type="text" 
        style="color: black">
    </div>
  </div>
  <div class="row" *ngIf="chapterRows && chapterRows.length > 0">
    <table class="table table-bordered" style="margin: 5px;">
      <tbody>
          <tr>
              <th colspan="3" style="text-align: center;">Chapter</th>
          </tr>
          <tr class="d-flex" *ngFor="let chapterRow of chapterRows">
          <td 
            align="center" 
            class="col-sm-4" 
            *ngFor="let chapter of chapterRow" 
            style="font-size: 1.5em" 
            (click)="selectChapter(chapter)">
            {{chapter}}
          </td>
        </tr>
      </tbody>
    </table>
  </div>
  <div class="row">
    <div *ngIf="chapter && chapter > 0" style="margin: 5px;">
        <h4 style="text-align: center;">Chapter: {{chapter}}</h4>
        <div style="text-align: center; font-size: 1.2em;">
          Start: <input (focus)="$event.target.select()" [value]="startVerse" (change)="changeStartVerse($event)" size="1" width="1" type="text" style="color: black"> &nbsp;
          End: <input (focus)="$event.target.select()" [value]="endVerse" (change)="changeEndVerse($event)" size="1" width="1" type="text" style="color: black"> &nbsp;
          <span *ngIf="startVerse && startVerse > 0 && endVerse && endVerse > 0">Append:</span> <input *ngIf="startVerse && startVerse > 0 && endVerse && endVerse > 0" (focus)="$event.target.select()" [(ngModel)]="append" size="1" width="1" type="text" style="color: black"> &nbsp;
        </div>
        <div style="margin: 5px;">
          {{translationLongName}} &nbsp;&nbsp;
          <button (click)="addPassage()" *ngIf="startVerse && startVerse > 0 && endVerse && endVerse > 0" class="btn btn-primary" type="button">Add</button>&nbsp;
          <button (click)="editPassage()" *ngIf="!editing && startVerse && startVerse > 0 && endVerse && endVerse > 0" class="btn btn-primary float-right" type="button"><i style="font-size: 18px !important;" class="fa fa-edit"></i></button>
          <button (click)="updatePassage()" *ngIf="editing && startVerse && startVerse > 0 && endVerse && endVerse > 0" class="btn btn-primary float-right" type="button"><i style="font-size: 18px !important;" class="fa fa-check-square-o"></i></button>
        </div>
    </div>
  </div>
  <div class="row" *ngIf="startVerse && startVerse > 0 && endVerse && endVerse > 0">
    <hr/>
    <div *ngIf="!editing" [innerHTML]="passageHtml" style="padding: 10px;"></div>
    <div class="col-sm" *ngIf="editing" style="padding: 10px;">
      <textarea cols="50" rows="10" [(ngModel)]="currPassageText"></textarea>
    </div>
  </div>
</div>