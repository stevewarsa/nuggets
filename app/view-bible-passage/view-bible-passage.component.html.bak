<div class="container" (swipeleft)="swipe($event.type)" (swiperight)="swipe($event.type)">
  <mem-passage-navigation (nextEvent)="next()" (prevEvent)="prev()" (answerEvent)="answer()" (stopPracticeEvent)="stop()" [progressString]="progressString" [showPassageTextFirst]="_showPsgText" [frequencyDays]="_passage?.frequencyDays" [lastPracticedDate]="_passage?.last_viewed_num" [swipeEvent]="direction"></mem-passage-navigation>
  <div class="row" *ngIf="!_showPsgText">
    <!-- This is the case where we're showing the passage ref and user needs to recite the verse-->
    <div class="col-md col-lg col-sm">
      <div *ngIf="!searching" class="nugget-view" [innerHTML]="passageRef" style="text-align: center;"></div>
      <div *ngIf="searching" style="text-align: center;">
        <p class="lead">{{searchingMessage}}</p><img src="assets/ajax-loader.gif" />
      </div>
    </div>
  </div>
  <div class="row" *ngIf="_showPsgText">
    <div class="col-md col-lg col-sm">
    <!-- This is the case where we're showing the verse and user needs to recite the passage ref -->
    <div *ngIf="!searching" class="nugget-view" [innerHTML]="formattedPassageText" style="text-align: center;"></div>
      <div *ngIf="searching" style="text-align: center;">
        <p class="lead">{{searchingMessage}}</p><img src="assets/ajax-loader.gif" />
      </div>
    </div>
  </div>
</div>
